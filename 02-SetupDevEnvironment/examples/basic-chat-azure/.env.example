# Azure AI Foundry (Azure OpenAI) configuration - keyless (Microsoft Entra ID)
# Copy this file to .env and fill in your values, OR run `azd up` from
# 02-SetupDevEnvironment/ to generate this file automatically.
#
# Authentication is keyless: there is NO API key. Sign in with `az login`
# (locally) or use a managed identity. Your account needs the
# "Cognitive Services OpenAI User" role on the Foundry resource.

# Your Foundry (Azure OpenAI) endpoint URL (e.g., https://<resource>.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Chat model deployment name (default is gpt-4o-mini)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Optional: embedding deployment name (used by later chapters)
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
